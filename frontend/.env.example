# ============================================================
# FinSight AI — Frontend Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# Backend API URL
# Development (FastAPI running locally)
VITE_API_URL=http://127.0.0.1:8000

# Production (change to your EC2 / deployed backend URL)
# VITE_API_URL=https://api.yourdomain.com

# Optional: Analytics, monitoring
# VITE_SENTRY_DSN=
# VITE_GA_ID=
